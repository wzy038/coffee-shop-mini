.float-ball {
  position: fixed;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B4513 0%, #D2691E 50%, #F4A460 100%);
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  cursor: pointer;
  transition: transform 0.2s ease;
}

.float-ball:active {
  transform: scale(0.95);
}

.ball-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ai-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #FFFFFF;
  line-height: 1;
}

.custom-text {
  font-size: 10rpx;
  color: #FFFFFF;
  line-height: 1;
  margin-top: 2rpx;
}