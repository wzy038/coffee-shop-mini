.page {
  min-height: 100vh;
  background: #f7f7f7;
}

.header-card {
  background: linear-gradient(135deg, #d48b47, #b47c4e);
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-icon {
  font-size: 56rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.user-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.edit-btn {
  background: rgba(255, 255, 255, 0.95);
  color: #b47c4e;
  font-size: 26rpx;
  padding: 14rpx 32rpx;
  border-radius: 40rpx;
}

.info-list {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 180rpx;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.info-value.highlight {
  color: #d48b47;
  font-weight: bold;
}

.action-list {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.action-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.action-arrow {
  font-size: 26rpx;
  color: #999;
}

.edit-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.edit-modal {
  width: 700rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 56rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  padding: 50rpx 40rpx;
}

.form-item {
  margin-bottom: 50rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 32rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  height: 100rpx;
  padding: 0 32rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  line-height: 100rpx;
}

.avatar-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.avatar-item .form-label {
  margin-bottom: 0;
}

.avatar-upload {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 2rpx dashed #d48b47;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 40rpx;
}

.upload-text {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f5f5f5;
}

.modal-cancel,
.modal-confirm {
  flex: 1;
  padding: 40rpx;
  font-size: 34rpx;
  border: none;
  border-radius: 0;
}

.modal-cancel {
  color: #666;
  background: #f7f7f7;
}

.modal-confirm {
  color: #fff;
  background: #d48b47;
}