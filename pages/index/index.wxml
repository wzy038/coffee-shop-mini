<scroll-view scroll-y class="page-wrap">
  <view class="status-bar-placeholder" style="height: {{statusBarHeight}}px"></view>
  <view class="nav-bar">
    <text class="nav-title">Cocount</text>
  </view>
  <view class="top-banner">
    <image class="banner-img" src="/pages/index/static/images/back.jpg" mode="aspectFill" style="height: 505rpx; display: inline-block; box-sizing: border-box"></image>
  </view>

  <view class="main-content">
    <view class="action-buttons">
      <view class="action-item" bindtap="goOrder" style="height: 381rpx; display: flex; box-sizing: border-box; width: 322rpx">
        <image class="action-icon" src="/pages/index/static/images/left.jpg" mode="aspectFit" style="width: 300rpx; height: 245rpx; display: block; box-sizing: border-box; position: relative; left: 0rpx; top: -35rpx"></image>
        <text class="action-title" style="position: relative; left: 0rpx; top: -29rpx">点单</text>
        <text class="action-desc" style="position: relative; left: 1rpx; top: -18rpx">自提点单 享受楦美</text>
      </view>
      <view class="action-item" bindtap="goTakeaway" style="width: 340rpx; display: flex; box-sizing: border-box; height: 381rpx">
        <image class="action-icon" src="/pages/index/static/images/right.jpg" mode="aspectFit" style="width: 314rpx; height: 234rpx; display: block; box-sizing: border-box; position: relative; left: 2rpx; top: -34rpx"></image>
        <text class="action-title" style="position: relative; left: 2rpx; top: -29rpx">外卖配送</text>
        <text class="action-desc" style="position: relative; left: 3rpx; top: -16rpx">现在下单 楦美到家</text>
      </view>
    </view>

    <view class="member-card">
      <view class="member-left">
        <view class="member-info">
          <text class="member-greeting" style="width: 128rpx; display: block; box-sizing: border-box">Hi 你好</text>
          <text class="member-level">普通等级</text>
        </view>
        <view class="member-stats">
          <view class="stat-item">
            <text class="stat-label">余额</text>
            <text class="stat-value">{{balance}}</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-label">积分</text>
            <text class="stat-value">{{integral}}</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-label">优惠券</text>
            <text class="stat-value">{{couponCount}}</text>
          </view>
        </view>
      </view>
      <view class="member-right">
        <text class="progress-text">0/128</text>
        <text class="member-code-btn" bindtap="goMemberCode">会员码</text>
      </view>
    </view>

    <view class="bottom-buttons">
      <view class="bottom-item" bindtap="goMine">
        <image class="bottom-icon" src="/pages/index/static/images/gerenzhongxin.png" mode="aspectFit"></image>
        <text class="bottom-title">个人中心</text>
        <text class="bottom-subtitle">Personal</text>
      </view>
      <view class="bottom-item" bindtap="goRecharge">
        <image class="bottom-icon" src="/pages/index/static/images/huiyuan.png" mode="aspectFit"></image>
        <text class="bottom-title">会员充值</text>
        <text class="bottom-subtitle">Recharge</text>
      </view>
      <view class="bottom-item" bindtap="goIntegral">
        <image class="bottom-icon" src="/pages/index/static/images/jifen.png" mode="aspectFit"></image>
        <text class="bottom-title">积分商城</text>
        <text class="bottom-subtitle">Benefits</text>
      </view>
    </view>
  </view>
</scroll-view>

<view wx:if="{{showMemberCode}}" class="member-code-modal" bindtap="closeMemberCode">
  <view class="modal-content" catchtap="preventClose">
    <view class="modal-header">
      <text class="modal-title">会员码</text>
      <text class="modal-close" bindtap="closeMemberCode">×</text>
    </view>
    <view class="member-card-content">
      <view class="card-header">
        <text class="card-title">Cocount</text>
        <text class="card-subtitle">咖啡鲜果茶轻食</text>
      </view>
      <view class="card-info">
        <view class="user-avatar" wx:if="{{userInfo.avatar}}">
          <image src="{{userInfo.avatar}}" mode="aspectFill" />
        </view>
        <view class="user-avatar" wx:else>
          <text class="avatar-text">{{userInfo.nickName ? userInfo.nickName.charAt(0) : 'U'}}</text>
        </view>
        <view class="user-info">
          <text class="user-name">{{userInfo.nickName || 'Cocount用户'}}</text>
          <text class="user-phone">{{userInfo.phone || '未绑定手机号'}}</text>
        </view>
      </view>
      <view class="qrcode-section">
        <view class="qrcode-box">
          <canvas canvas-id="qrcodeCanvas" class="qrcode-canvas" width="250" height="250"></canvas>
          <view class="qrcode-mask" wx:if="{{!qrcodeReady}}">
            <text class="loading-text">生成中...</text>
          </view>
        </view>
        <text class="qrcode-tip">出示此码可享受会员优惠</text>
      </view>
      <view class="card-stats">
        <view class="card-stat">
          <text class="stat-num">{{userInfo.balance || 0}}</text>
          <text class="stat-name">余额(元)</text>
        </view>
        <view class="card-stat">
          <text class="stat-num">{{userInfo.integral || 0}}</text>
          <text class="stat-name">积分</text>
        </view>
        <view class="card-stat">
          <text class="stat-num">{{userInfo.couponCount || 0}}</text>
          <text class="stat-name">优惠券</text>
        </view>
      </view>
    </view>
  </view>
</view>