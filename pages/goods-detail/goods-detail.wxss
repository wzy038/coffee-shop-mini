page {
  background: #fff;
  font-size: 28rpx;
  padding-bottom: 180rpx;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 60rpx 30rpx 20rpx;
  z-index: 100;
}
.back {
  font-size: 48rpx;
  color: #333;
}
.share {
  font-size: 36rpx;
  color: #333;
}

.img-wrap {
  position: relative;
  width: 100%;
}
.goods-main-img {
  width: 100%;
  height: 600rpx;
}
.img-tags {
  position: absolute;
  bottom: 30rpx;
  left: 30rpx;
  display: flex;
  gap: 12rpx;
}
.img-tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #fff;
}
.img-tag.green {
  background: rgba(0, 180, 100, 0.9);
}
.brand-badge {
  position: absolute;
  top: 120rpx;
  right: 30rpx;
  width: 120rpx;
  height: 120rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}
.badge-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.goods-info {
  padding: 30rpx;
}
.info-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.goods-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #222;
  flex: 1;
}
.save-taste {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 20rpx;
}
.heart-icon {
  font-size: 36rpx;
  color: #999;
}
.save-text {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.section {
  padding: 30rpx 30rpx;
  border-top: 1rpx solid #f5f5f5;
}
.section-title {
  font-size: 25rpx;
  font-weight: normal;
  color: black;
  margin-bottom: 24rpx;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.option-row.three-col .option-item.bean {
  width: calc(33.33% - 14rpx);
}
.option-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-item {
  display: flex;
  flex-direction: column;
  padding: 24rpx 28rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 16rpx;
  background: #fff;
  position: relative;
}
.option-item.active {
  border-color: #2b6aff;
  background: #fff;
}

.option-item.simple {
  padding: 24rpx 48rpx;
}

.option-item.grid {
  padding: 24rpx 20rpx;
  width: calc(33.33% - 12rpx);
}

.option-top-tag {
  position: absolute;
  top: -16rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #2b6aff;
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.option-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.option-text-wrap {
  display: flex;
  flex-direction: column;
}

.option-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #222;
}

.option-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.bean-tag {
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  margin-bottom: 8rpx;
  display: inline-block;
}
.bean-tag.blue {
  color: #2b6aff;
  background: #f0f6ff;
}
.bean-tag.dark {
  color: #333;
  background: #f5f5f5;
}
.bean-tag.gold {
  color: #b47c4e;
  background: #fff8f0;
}

.bean-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #222;
}

.bean-desc {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
}

.option-item.grid .recommend-tag {
  font-size: 18rpx;
  color: #2b6aff;
  margin-top: 4rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #fff;
  display: flex;
  flex-direction: column;
  padding: 16rpx 30rpx;
  border-top: 1rpx solid #eee;
  gap: 12rpx;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-area {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.price-symbol {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff4d4f;
}
.price {
  font-size: 44rpx;
  font-weight: bold;
  color: #ff4d4f;
}
.price-desc {
  font-size: 22rpx;
  color: #ff4d4f;
  margin-left: 4rpx;
}
.price-original {
  font-size: 22rpx;
  color: #ccc;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.spec-desc {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.num-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.num-btn {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 28rpx;
  padding: 0;
  border-radius: 40%;
  border: none;
}
.minus-btn {
  background: #fff;
  color: #999;
  border: 1rpx solid #e5e5e5;
}
.plus-btn {
  background: #2b6aff;
  color: #fff;
}
.num {
  font-size: 28rpx;
  font-weight: bold;
  width: 40rpx;
  text-align: center;
}

.btn-row {
  display: flex;
  gap: 16rpx;
}

.add-cart-btn {
  flex: 1;
  background: #f5e6d3;
  color: black;
  padding: 20rpx;
  border-radius: 35rpx;
  font-size: 28rpx;
  border: none;
  font-weight: 500;
}

.buy-now-btn {
  flex: 1.5;
  background: #2b6aff;
  color: white;
  padding: 20rpx;
  border-radius: 35rpx;
  font-size: 28rpx;
  border: none;
  font-weight: 500;
}
