.mine {
  min-height: 100vh;
  position: relative;
}

.status-bar-placeholder {
  background: rgba(245, 235, 224, 0.95);
}

.nav-bar {
  height: 88rpx;
  background: rgba(245, 235, 224, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #000;
}

.bg-image {
  position: fixed;
  top: 80rpx;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.pet-placeholder {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #d48b47, #c4956a);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.bg-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.bg-section {
  padding: 120rpx 30rpx 40rpx;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-wrap {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #c4956a;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-icon {
  font-size: 48rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.user-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 6rpx;
}

.login-btn {
  background: #c4956a;
  color: #fff;
  font-size: 26rpx;
  padding: 14rpx 32rpx;
  border-radius: 40rpx;
  border: none;
}

.info-box {
  margin-top: 30rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.info-text {
  flex: 1;
}

.info-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.info-sub {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-top: 6rpx;
}

.info-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.info-login-btn {
  background: #c4956a;
  color: #fff;
  font-size: 26rpx;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  border: none;
  text-align: center;
  box-sizing: border-box;
}

.stats-card {
  display: flex;
  margin: 0 30rpx 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  background: #eee;
  margin: 0 20rpx;
}

.menu-list {
  margin: 0 30rpx 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 26rpx;
  color: #999;
}

.login-page {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  overflow: hidden;
}

.login-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #FDE89B 0%, #F5D67B 100%);
}

.login-content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.pet-icon {
  width: 200rpx;
  height: 200rpx;
  background: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  overflow: hidden;
}

.pet-img {
  width: 100%;
  height: 100%;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 80rpx;
}

.login-buttons {
  width: 85%;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  margin: 0;
}

.login-btn::after {
  border: none;
}

.wechat-btn {
  background: #fff;
}

.phone-btn {
  background: #fff;
}

.btn-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.btn-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.agreement-box {
  display: flex;
  align-items: center;
  margin-top: 40rpx;
  padding: 0 40rpx;
  flex-wrap: wrap;
}

.checkbox-wrap {
  padding: 6rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #999;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background: #C4956A;
  border-color: #C4956A;
}

.check-icon {
  font-size: 24rpx;
  color: #fff;
}

.agreement-text {
  font-size: 24rpx;
  color: #666;
  margin-left: 10rpx;
}

.agreement-link {
  font-size: 24rpx;
  color: #C4956A;
  margin-left: 4rpx;
}

.paw-prints {
  position: absolute;
  bottom: 100rpx;
  width: 100%;
  height: 300rpx;
  z-index: 5;
}

.paw {
  position: absolute;
  font-size: 80rpx;
  opacity: 0.8;
}

.paw-1 {
  left: 10%;
  bottom: 60%;
  transform: rotate(-15deg);
}

.paw-2 {
  right: 15%;
  bottom: 40%;
  transform: rotate(15deg);
}

.paw-3 {
  left: 30%;
  bottom: 20%;
  transform: rotate(-10deg);
}

.paw-4 {
  right: 30%;
  bottom: 5%;
  transform: rotate(10deg);
}

.wechat-account-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.wechat-account-modal {
  width: 680rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.account-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.account-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.account-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.account-list {
  padding: 20rpx;
}

.account-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
  margin-bottom: 16rpx;
}

.account-item:active {
  background: #f0f0f0;
}

.account-item.loading {
  background: #f8f8f8;
}

.account-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.loading-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  font-size: 48rpx;
}

.account-info {
  flex: 1;
}

.account-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.account-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.account-check {
  width: 56rpx;
  height: 56rpx;
  background: #07c160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 32rpx;
  color: #fff;
}

.account-footer {
  padding: 24rpx 40rpx 40rpx;
  border-top: 1rpx solid #f0f0f0;
}

.switch-account {
  padding: 20rpx;
  text-align: center;
  border-radius: 12rpx;
  background: #f8f8f8;
}

.switch-account:active {
  background: #f0f0f0;
}

.switch-text {
  font-size: 30rpx;
  color: #333;
}

.phone-login-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.phone-login-modal {
  width: 680rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.phone-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.phone-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.phone-modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.phone-modal-body {
  padding: 40rpx;
}

.input-group {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.phone-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: #333;
}

.phone-submit-btn {
  width: 100%;
  height: 96rpx;
  background: #C4956A;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-top: 20rpx;
}

.phone-submit-btn::after {
  border: none;
}

.phone-modal-footer {
  padding: 24rpx 40rpx 40rpx;
  text-align: center;
}

.switch-auth {
  font-size: 28rpx;
  color: #C4956A;
}

.close-btn-wrap {
  text-align: center;
  margin-top: 20rpx;
}

.close-btn {
  font-size: 28rpx;
  color: #999;
}