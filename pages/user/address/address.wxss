page {
  background: #f5f5f5;
}
.page {
  padding-bottom: 120rpx;
}
.header {
  display: flex;
  align-items: center;
  height: 90rpx;
  background: #fff;
  padding: 0 30rpx;
}
.back {
  font-size: 36rpx;
  width: 60rpx;
}
.title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
}
.placeholder {
  width: 60rpx;
}

/* 地址列表 */
.addr-list {
  background: #f5f5f5;
}
.addr-item {
  background: #fff;
  padding: 30rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}
.addr-main {
  flex: 1;
}
.addr-region {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.addr-detail {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
  line-height: 1.4;
}
.addr-user {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.user-name {
  font-size: 28rpx;
  color: #333;
}
.user-phone {
  font-size: 26rpx;
  color: #666;
}
.default-tag {
  font-size: 20rpx;
  color: #ff6600;
  background: #fff5f0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.addr-edit {
  padding: 20rpx;
}
.edit-icon {
  font-size: 36rpx;
  color: #999;
}
.list-bottom {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: #999;
}
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}
.empty-icon {
  width: 150rpx;
  height: 150rpx;
  display: block;
  margin: 0 auto 20rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 表单区域 */
.form-wrap {
  background: #fff;
  margin-top: 20rpx;
}
.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}
.form-label {
  width: 160rpx;
  font-size: 30rpx;
  color: #333;
}
.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #666;
}
.region-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.region-text {
  font-size: 28rpx;
  color: #333;
}
.region-placeholder {
  font-size: 28rpx;
  color: #999;
}
.region-arrow {
  font-size: 28rpx;
  color: #999;
}
.gender-wrap {
  flex: 1;
  display: flex;
  gap: 60rpx;
}
.gender-option {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.gender-radio {
  width: 30rpx;
  height: 30rpx;
  border: 2rpx solid #999;
  border-radius: 50%;
}
.gender-option.active .gender-radio {
  border-color: #d48b47;
  background: #d48b47;
}
.gender-text {
  font-size: 28rpx;
}
.checkbox-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.checkbox {
  width: 30rpx;
  height: 30rpx;
  border: 2rpx solid #999;
  border-radius: 6rpx;
}
.checkbox.checked {
  background: #d48b47;
  border-color: #d48b47;
}
.checkbox-text {
  font-size: 28rpx;
}

/* 底部按钮 */
.add-btn {
  margin: 40rpx 30rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #fff;
  border: 1rpx solid #d48b47;
  color: #d48b47;
  border-radius: 10rpx;
  font-size: 32rpx;
}
.save-btn {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #d48b47;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
  z-index: 100;
  margin: 0;
  padding: 0;
}
.save-btn::after {
  border: none;
}

/* 定位失败弹窗 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.tip-box {
  width: 620rpx;
  background: #1a1a1a;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.tip-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 32rpx;
}
.tip-text {
  font-size: 28rpx;
  color: #cccccc;
  margin-bottom: 60rpx;
  text-align: center;
}
.tip-btn {
  width: 260rpx;
  text-align: center;
  font-size: 32rpx;
  color: #ffffff;
}

/* 地区选择弹窗 */
.region-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  z-index: 999;
}
.region-picker {
  width: 100%;
  background: #fff;
  position: absolute;
  bottom: 0;
  left: 0;
  border-radius: 20rpx 20rpx 0 0;
}
.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}
.picker-title {
  font-size: 32rpx;
  font-weight: 500;
}
.picker-cancel {
  font-size: 30rpx;
  color: #999;
}
.picker-content {
  height: 400rpx;
}
.picker-view {
  width: 100%;
  height: 400rpx;
}
.picker-col-item {
  line-height: 68rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}
.picker-col-item.active {
  color: #d48b47;
  font-weight: 500;
}
.picker-footer {
  padding: 30rpx;
  border-top: 1rpx solid #eee;
}
.picker-confirm {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #d48b47;
  color: #fff;
  border-radius: 10rpx;
  font-size: 32rpx;
}