page {
  background: #fdfbf7;
  min-height: 100vh;
}

.page {
  min-height: 100vh;
}

.balance-header {
  position: relative;
  padding: 80rpx 30rpx 60rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, #d4a87a 0%, #c4956a 100%);
}

.header-bg::before {
  content: '';
  position: absolute;
  top: -40%;
  right: -15%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
}

.header-bg::after {
  content: '';
  position: absolute;
  bottom: -20%;
  left: -10%;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.balance-content {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 40rpx;
}

.balance-info {
  text-align: center;
  margin-bottom: 36rpx;
}

.balance-label {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.balance-value {
  display: block;
  font-size: 88rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.2;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.balance-row {
  display: flex;
  justify-content: center;
}

.balance-col {
  flex: 1;
  text-align: center;
}

.col-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.col-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
}

.col-divider {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 20rpx;
}

.main-content {
  padding: 0 30rpx 40rpx;
  margin-top: -30rpx;
  position: relative;
  z-index: 2;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.recharge-btn {
  flex: 1;
  background: linear-gradient(135deg, #d4a87a 0%, #c4956a 50%, #a67c52 100%);
  border-radius: 40rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 6rpx 20rpx rgba(212, 168, 122, 0.4);
}

.detail-btn {
  flex: 1;
  background: #fff;
  border: 2rpx solid #d4a87a;
  border-radius: 40rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: bold;
}

.recharge-btn .btn-text {
  color: #fff;
}

.detail-btn .btn-text {
  color: #c4956a;
}

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-card {
  width: calc(50% - 8rpx);
  background: #fafafa;
  border-radius: 16rpx;
  padding: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.option-card.highlight {
  background: #fff8f0;
  border-color: #d4a87a;
}

.option-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.option-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.option-card.highlight .option-price {
  color: #c4956a;
}

.option-tag {
  font-size: 20rpx;
  color: #999;
  background: #f0f0f0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.option-tag.highlight-tag {
  background: linear-gradient(135deg, #d4a87a 0%, #c4956a 100%);
  color: #fff;
}

.option-gift {
  display: block;
  font-size: 26rpx;
  color: #d4a87a;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.option-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.tips-box {
  padding: 20rpx;
  background: #fdfbf7;
  border-radius: 12rpx;
}

.tip-item {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.detail-modal {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

.modal-title {
  display: block;
  text-align: center;
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.input-box {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.input-prefix {
  font-size: 36rpx;
  font-weight: bold;
  color: #666;
  margin-right: 16rpx;
}

.money-input {
  flex: 1;
  background: transparent;
  padding: 30rpx 0;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.quick-amounts {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.quick-tag {
  background: #f8f8f8;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.quick-tag:active {
  background: #fff8f0;
  color: #c4956a;
  border-color: #d4a87a;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.modal-cancel {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border-radius: 40rpx;
  padding: 30rpx;
  font-size: 32rpx;
  text-align: center;
}

.modal-confirm {
  flex: 1;
  background: linear-gradient(135deg, #d4a87a 0%, #c4956a 50%, #a67c52 100%);
  color: #fff;
  border-radius: 40rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(212, 168, 122, 0.4);
}

.modal-close-btn {
  background: #f5f5f5;
  color: #666;
  border-radius: 40rpx;
  padding: 30rpx;
  font-size: 32rpx;
  text-align: center;
  margin-top: 20rpx;
}

.detail-scroll {
  flex: 1;
  max-height: 50vh;
}

.record-list {
  background: #fafafa;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.record-item:nth-child(odd) .record-icon {
  background: rgba(212, 168, 122, 0.15);
  color: #c4956a;
}

.record-item:nth-child(even) .record-icon {
  background: rgba(255, 107, 107, 0.15);
  color: #ff6b6b;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-type {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.record-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.record-amount {
  font-size: 32rpx;
  font-weight: bold;
}

.record-amount.income {
  color: #c4956a;
}

.record-amount.expense {
  color: #ff6b6b;
}

.empty-state {
  text-align: center;
  padding: 60rpx 30rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
