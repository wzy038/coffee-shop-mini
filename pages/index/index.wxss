page {
  font-family: "PingFang SC", "Source Han Sans CN", sans-serif;
  background: #d4a87a;
}

.status-bar-placeholder {
  background: #d4a87a;
}

.nav-bar {
  height: 88rpx;
  background: #d4a87a;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #000;
}

.page-wrap {
  width: 100%;
  min-height: 100vh;
  position: relative;
}

.top-banner {
  width: 100%;
  height: 520rpx;
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.main-content {
  padding: 0 30rpx 30rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
}

.action-buttons {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.action-item {
  flex: 1;
  background: linear-gradient(135deg, #c4956a 0%, #a67c52 100%);
  border-radius: 24rpx;
  padding: 36rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(166, 124, 82, 0.3);
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 16rpx;
}

.action-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.member-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.member-left {
  flex: 1;
}

.member-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.member-greeting {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.member-level {
  font-size: 24rpx;
  color: #c4956a;
  background: #fff8f0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.member-stats {
  display: flex;
  align-items: center;
  gap: 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.stat-value {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #eee;
}

.member-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-left: 30rpx;
  border-left: 1rpx solid #eee;
}

.progress-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #c4956a;
  margin-bottom: 12rpx;
}

.member-code-btn {
  font-size: 26rpx;
  color: #c4956a;
  border: 2rpx solid #c4956a;
  padding: 10rpx 32rpx;
  border-radius: 30rpx;
}

.bottom-buttons {
  display: flex;
  gap: 20rpx;
}

.bottom-item {
  flex: 1;
  background: linear-gradient(135deg, #d4a87a 0%, #c4956a 100%);
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 6rpx 16rpx rgba(166, 124, 82, 0.25);
}

.bottom-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 12rpx;
}

.bottom-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.bottom-subtitle {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 300;
}

.member-code-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 95%;
  max-width: 800rpx;
  background: #fff;
  border-radius: 32rpx;
  overflow: visible;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx;
  background: linear-gradient(135deg, #d4a87a 0%, #c4956a 100%);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.modal-close {
  font-size: 56rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1;
}

.member-card-content {
  padding: 40rpx;
}

.card-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.card-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #c4956a;
  margin-bottom: 8rpx;
}

.card-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.card-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 36rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx dashed #eee;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #d4a87a 0%, #c4956a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.user-phone {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.qrcode-section {
  text-align: center;
  margin-bottom: 32rpx;
}

.qrcode-box {
  width: 500rpx;
  height: 500rpx;
  margin: 0 auto;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  padding: 0;
  position: relative;
}

.qrcode-canvas {
  width: 500rpx;
  height: 500rpx;
  display: block;
  margin: 0 auto;
}

.qrcode-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #c4956a;
}

.qrcode-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.card-stats {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  background: #fdfbf7;
  border-radius: 16rpx;
}

.card-stat {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #c4956a;
  margin-bottom: 8rpx;
}

.stat-name {
  display: block;
  font-size: 22rpx;
  color: #999;
}
