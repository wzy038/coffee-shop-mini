# 环境变量示例文件
# 使用方法：复制此文件为 .env 并修改对应的值
# 命令：cp .env.example .env

# Flask 运行环境（development / production / testing）
FLASK_ENV=development

# Flask 密钥（生产环境请务必修改为随机字符串）
SECRET_KEY=coffee-mini-secret-key-change-me

# JWT 签名密钥（建议与 SECRET_KEY 不同）
JWT_SECRET_KEY=jwt-secret-key-change-me

# 数据库连接地址
# SQLite（默认，学生本地开发推荐）：sqlite:///coffee.db
# MySQL：mysql+pymysql://用户名:密码@主机:端口/数据库名
# PostgreSQL：postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=sqlite:///coffee.db

# 服务监听地址和端口
HOST=127.0.0.1
PORT=5000
