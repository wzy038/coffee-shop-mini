.page {
  min-height: 100vh;
  background: #fdf6e9;
}

.header {
  position: relative;
  padding: 60rpx 30rpx 20rpx;
  background: #8fb593;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  padding-top: 20rpx;
}

.point-card {
  background: #fdf0d9;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.point-info {
  color: #333;
}

.point-label {
  font-size: 28rpx;
  color: #666;
}

.point-value {
  display: block;
  font-size: 60rpx;
  font-weight: bold;
  margin-top: 10rpx;
  color: #333;
}

.exchange-btn {
  background: #8fb593;
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  margin: 40rpx 20rpx 0;
  border-radius: 16rpx;
  padding: 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 1;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: #8fb593;
  color: #fff;
}

.goods-section {
  padding: 20rpx;
  position: relative;
  z-index: 2;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #8fb593;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
  position: relative;
  z-index: 2;
}

.goods-item {
  width: calc(50% - 20rpx);
  background: #fff;
  margin: 10rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.goods-img {
  width: 100%;
  height: 280rpx;
}

.goods-info {
  padding: 0 20rpx;
}

.goods-name {
  display: block;
  padding: 20rpx 0 8rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  text-align: center;
}

.goods-point {
  display: block;
  padding: 0 0 16rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.goods-btn {
  margin: 0 20rpx 20rpx;
  background: #8fb593;
  color: #fff;
  text-align: center;
  padding: 14rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.footer {
  margin: 40rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.footer-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.footer-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.footer-icons {
  display: flex;
  justify-content: space-around;
}

.footer-icon-item {
  text-align: center;
}

.footer-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.footer-icon-text {
  font-size: 22rpx;
  color: #666;
}
